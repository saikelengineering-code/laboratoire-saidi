            .burger { display: block; z-index: 1000; }
            .hero h1 { font-size: 2rem; }
            .hero-subtitle { font-size: 1.1rem; }
            .hero-buttons { flex-direction: column; align-items: center; }
            .btn-hero { width: 100%; max-width: 280px; text-align: center; }
            section { padding: 60px 5%; }
            .floating-actions { bottom: 20px; right: 20px; }
            .float-btn { width: 50px; height: 50px; font-size: 1.3rem; }
            .map-wrapper iframe { height: 350px; }
