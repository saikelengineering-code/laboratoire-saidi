        }
        .float-btn {
            width: 55px; height: 55px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 1.5rem; text-decoration: none;
            box-shadow: 0 5px 20px rgba(0,0,0,0.25);
            transition: var(--transition);
            animation: pulse 2.5s infinite;
        }
        .float-btn:hover { transform: scale(1.1); animation: none; }
        .whatsapp { background: #25D366; }
        .telegram { background: #0088cc; }
        .devis-rapide { background: var(--accent-color); animation: none; }

        @keyframes pulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.6); }
            50% { box-shadow: 0 0 0 15px rgba(37, 211, 102, 0); }
        }

        footer {
            background: #081f33; color: rgba(255,255,255,0.7);
            text-align: center; padding: 30px 20px; font-size: 0.9rem;
        }
        footer strong { color: var(--white); }
        footer a { color: var(--secondary-color); }
        .footer-links {
            margin: 20px 0;
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
        }
        .footer-links a {
            color: rgba(255,255,255,0.8);
            transition: var(--transition);
        }
        .footer-links a:hover { color: var(--accent-color); }

        /* --- ANIMATIONS --- */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .reveal { opacity: 0; transform: translateY(30px); transition: all 0.7s ease; }
        .reveal.active { opacity: 1; transform: translateY(0); }

        /* --- RESPONSIVE --- */
        @media (max-width: 992px) {
            .hero h1 { font-size: 2.6rem; }
            .contact-container { grid-template-columns: 1fr; }
            .form-row { grid-template-columns: 1fr; }
